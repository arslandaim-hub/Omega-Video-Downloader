default_platform(:android)

platform :android do
  desc "Check for F-Droid compliance (metadata)"
  lane :metadata_check do
    # This lane can be expanded for automated metadata validation
    puts "Fastlane metadata is located in app/src/main/fastlane/metadata"
  end

  desc "Build the app for testing"
  lane :build do
    gradle(task: "assembleDebug")
  end
end
